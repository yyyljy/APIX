APIX_JWT_SECRET=change-this-secret
APIX_JWT_ISSUER=apix-cloud
APIX_JWT_KID=v1
APIX_JWT_TTL_SECONDS=60

# Demo mode
APIX_ENABLE_MOCK_VERIFY=true
APIX_MIN_CONFIRMATIONS=1

# Avalanche L1 payment profile (MVP defaults)
APIX_CHAIN_ID=402   
APIX_NETWORK=eip155:402
APIX_PAYMENT_CURRENCY=APIX
APIX_PAYMENT_AMOUNT=0.100000000000000000
APIX_PAYMENT_AMOUNT_WEI=100000000000000000
APIX_PAYMENT_RECIPIENT=0x71C7656EC7ab88b098defB751B7401B5f6d8976F

# Optional CORS allowlist (comma-separated). Use * only for local/demo.
APIX_ALLOWED_ORIGINS=http://localhost:5173

# Required when APIX_ENABLE_MOCK_VERIFY=false
# APIX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
# APIX_RPC_TIMEOUT_MS=8000
# APIX_RPC_MAX_RETRIES=2
