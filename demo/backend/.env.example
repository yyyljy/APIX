APIX_JWT_SECRET=change-this-secret
APIX_CHAIN_ID=402
APIX_NETWORK=eip155:402
APIX_PAYMENT_CURRENCY=APIX
APIX_PAYMENT_AMOUNT=0.1
APIX_PAYMENT_AMOUNT_WEI=100000000000000000
APIX_PAYMENT_RECIPIENT=0x0B3F82F42d05cEb8E4b33180Af782c0ccbDB25FC
# Managed EOA faucet sender (native APIX transfer).
APIX_FAUCET_ADMIN_PRIVATE_KEY=
APIX_FAUCET_RPC_URL=https://subnets.avax.network/apix/testnet/rpc
APIX_FAUCET_CURRENCY=APIX
APIX_FAUCET_AMOUNT=10
APIX_FAUCET_TOKEN_DECIMALS=18
APIX_FAUCET_COOLDOWN_SECONDS=86400
# Optional path override for per-wallet cooldown tracking.
# APIX_FAUCET_STORE_PATH=.tmp/apix-faucet-claims.json
# Optional test/dev bypass to skip real send and return a fixed tx hash.
# APIX_FAUCET_MOCK_TX_HASH=0x1111111111111111111111111111111111111111111111111111111111111111
# Backend on-chain verification RPC URL.
APIX_VERIFICATION_RPC_URL=http://localhost:9650/ext/bc/C/rpc
# For safer shared/CI environments, keep the endpoint in a mounted secret file.
# APIX_VERIFICATION_RPC_URL_FILE=/run/secrets/apix-verification-rpc-url
APIX_PROVIDER_TOKEN=provider-token-placeholder
APIX_RPC_TIMEOUT_MS=8000
APIX_RPC_MAX_RETRIES=2
APIX_MIN_CONFIRMATIONS=1
APIX_JWT_TTL_SECONDS=60
APIX_JWT_ISSUER=apix-sdk
APIX_JWT_KID=v1
APIX_HOST=localhost
